generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ScrapeSchedule {
  id             Int      @id @default(autoincrement())
  name           String
  platform       String
  frequency      String
  cronExpression String?
  target         String
  params         String   // JSON string
  webhookUrl     String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  executions     ScrapeExecution[]
}

model ScrapeExecution {
  id          Int      @id @default(autoincrement())
  scheduleId  Int
  schedule    ScrapeSchedule @relation(fields: [scheduleId], references: [id])
  status      String
  result      String?  // JSON string
  error       String?
  executedAt  DateTime @default(now())
  @@index([scheduleId])
}

model ProductData {
  id          String   @id @default(cuid())
  platform    String
  region      String
  productId   String
  shopId      String?
  name        String
  price       String
  priceBefore String?
  rating      Float?
  soldCount   Int?
  shopName    String
  url         String
  rawData     String?  // JSON string
  scrapedAt   DateTime @default(now())
  @@unique([platform, region, productId])
}

model RestaurantData {
  id            String   @id @default(cuid())
  platform      String
  region        String
  restaurantId  String
  name          String
  cuisine       String?
  rating        Float?
  deliveryFee   String?
  estimatedTime String?
  isOpen        Boolean?
  menu          String?  // JSON string
  scrapedAt     DateTime @default(now())
  @@unique([platform, region, restaurantId])
}

model WebhookConfig {
  id        Int      @id @default(autoincrement())
  name      String
  url       String
  events    String   // Comma-separated
  secret    String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Proxy {
  id           Int      @id @default(autoincrement())
  url          String   @unique
  type         String
  username     String?
  password     String?
  isHealthy    Boolean  @default(true)
  successCount Int      @default(0)
  failureCount Int      @default(0)
  lastUsed     DateTime?
  createdAt    DateTime @default(now())
}

model RateLimit {
  id        Int      @id @default(autoincrement())
  platform  String
  region    String
  remaining Int
  resetAt   DateTime
  createdAt DateTime @default(now())
  @@unique([platform, region])
}

model Alert {
  id         Int      @id @default(autoincrement())
  type       String
  platform   String?
  message    String
  data       String?  // JSON string
  isResolved Boolean  @default(false)
  createdAt  DateTime @default(now())
}
